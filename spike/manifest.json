{
  "manifest_version": 3,
  "name": "AdsAuditor Spike — Signal Logger",
  "version": "0.0.1",
  "description": "Throwaway Phase 0 measurement tool: logs YouTube player-response and ad-DOM signals for signal validation. Not for public distribution.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AdsAuditor Spike — Signal Logger"
  }
}
